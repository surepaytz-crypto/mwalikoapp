
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Mwaliko App.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "userRole": { "type": "string", "enum": ["SuperAdmin", "EventAdmin", "ScannerStaff"] }
      },
      "required": ["id", "email", "userRole"]
    },
    "Event": {
      "title": "Event",
      "type": "object",
      "description": "Represents a premium event with invitation settings and package limits.",
      "properties": {
        "id": { "type": "string" },
        "shortId": { "type": "string" },
        "nameEn": { "type": "string" },
        "nameSw": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "venue": { "type": "string" },
        "posterUrl": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "eventAdminId": { "type": "string" },
        "isActive": { "type": "boolean" },
        "isPaid": { "type": "boolean" },
        "packageType": { "type": "string", "enum": ["Standard", "Classic", "Premium"] },
        "guestLimit": { "type": "number" },
        "stats": { "type": "object" },
        "invitedTotals": { "type": "object" },
        "invitationSettings": {
          "type": "object",
          "properties": {
            "templateId": { "type": "string" },
            "title": { "type": "string" },
            "hostText": { "type": "string" },
            "brideName": { "type": "string" },
            "groomName": { "type": "string" },
            "rsvpText": { "type": "string" },
            "dressCode": { "type": "string" },
            "footerText": { "type": "string" },
            "showPhoto": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "shortId", "nameEn", "eventAdminId", "isActive", "packageType"]
    },
    "GuestEvent": {
      "title": "GuestEvent",
      "type": "object",
      "description": "Junction record for guests and events.",
      "properties": {
        "id": { "type": "string" },
        "guestId": { "type": "string" },
        "eventId": { "type": "string" },
        "guestName": { "type": "string" },
        "category": { "type": "string" },
        "ticketId": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "scannedGate": { "type": "boolean" },
        "scannedDrinks": { "type": "boolean" },
        "scannedFood": { "type": "boolean" },
        "qrCodeData": { "type": "string" }
      },
      "required": ["id", "guestName", "eventId", "category", "ticketId"]
    },
    "StaffAssignment": {
      "title": "StaffAssignment",
      "type": "object",
      "description": "Credentials and assignment for scanning staff.",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "assignedCheckpoint": { "type": "string", "enum": ["GATE", "DRINKS", "FOOD"] },
        "eventId": { "type": "string" },
        "eventName": { "type": "string" }
      },
      "required": ["username", "password", "assignedCheckpoint", "eventId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/events/{eventId}": { "schema": "Event", "description": "Premium events" },
    "/events/{eventId}/guestEvents/{guestEventId}": { "schema": "GuestEvent", "description": "Event-specific guest records" },
    "/events/{eventId}/staffAssignments/{staffId}": { "schema": "StaffAssignment", "description": "Staff access control" }
  }
}
