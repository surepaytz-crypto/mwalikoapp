
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Mwaliko App.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "userRole": { "type": "string", "enum": ["SuperAdmin", "EventAdmin", "ScannerStaff"] }
      },
      "required": ["id", "email", "userRole"]
    },
    "Event": {
      "title": "Event",
      "type": "object",
      "description": "Represents a premium event with 3-point scanning logic (Gate, Drinks, Food).",
      "properties": {
        "id": { "type": "string" },
        "nameEn": { "type": "string" },
        "nameSw": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "guestCapacity": { "type": "number" },
        "vipGuests": { "type": "number" },
        "standardGuests": { "type": "number" },
        "eventAdminId": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "nameEn", "eventAdminId", "isActive"]
    },
    "GuestEvent": {
      "title": "GuestEvent",
      "type": "object",
      "description": "Junction record for guests and events, tracking category and scan status.",
      "properties": {
        "id": { "type": "string" },
        "guestId": { "type": "string" },
        "eventId": { "type": "string" },
        "category": { "type": "string", "enum": ["VIP", "Standard"] },
        "scannedGate": { "type": "boolean" },
        "scannedDrinks": { "type": "boolean" },
        "scannedFood": { "type": "boolean" },
        "qrCodeData": { "type": "string" }
      },
      "required": ["id", "guestId", "eventId", "category", "qrCodeData"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/events/{eventId}": { "schema": "Event", "description": "Premium events" },
    "/events/{eventId}/guestEvents/{guestEventId}": { "schema": "GuestEvent", "description": "Event-specific guest records" }
  }
}
