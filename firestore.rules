rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements RBAC and DBAC tailored for event management.
     * It ensures event administrators can only view their own events and
     * staff can only view events they are assigned to.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_superAdmins/$(request.auth.uid));
    }

    function isEventAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_eventAdmins/$(request.auth.uid));
    }

    function isAssignedStaff(eventId) {
      return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/staffAssignments/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn() && (isOwner(userId) || isSuperAdmin());
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /roles_eventAdmins/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn(); // Allow role assignment for demo purposes or self-service
      allow update: if isSuperAdmin();
    }

    match /events/{eventId} {
      // List rules are strictly enforced: query must filter by eventAdminId or staff assignment
      allow get, list: if isSignedIn() && (
        isSuperAdmin() || 
        (resource != null && resource.data.eventAdminId == request.auth.uid) ||
        isAssignedStaff(eventId)
      );
      
      allow create: if isEventAdmin() && request.resource.data.eventAdminId == request.auth.uid;
      
      allow update, delete: if isSignedIn() && (
        isSuperAdmin() || 
        (resource != null && resource.data.eventAdminId == request.auth.uid)
      );
      
      // Allow access to subcollections
      match /{allSubcollections=**} {
        allow get, list, write: if isSignedIn() && (
          isSuperAdmin() || 
          isAssignedStaff(eventId) ||
          (get(/databases/$(database)/documents/events/$(eventId)).data.eventAdminId == request.auth.uid)
        );
      }
    }

    match /venues/{venueId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /{globalCollection}/{id} {
      function isGlobalCollection() {
        return globalCollection in ['guests', 'globalGuestCategories', 'globalInvitationTemplates'];
      }
      allow get, list: if isGlobalCollection() && isSignedIn();
      allow write: if isGlobalCollection() && isSuperAdmin();
    }
  }
}
