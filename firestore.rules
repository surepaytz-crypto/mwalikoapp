rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements RBAC and DBAC tailored for event management.
     * It ensures event administrators can only view their own events and
     * staff can only view events they are assigned to.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserData().userRole == 'SuperAdmin';
    }

    function isEventAdmin() {
      return isSignedIn() && getUserData().userRole == 'EventAdmin';
    }

    function isScannerStaff() {
      return isSignedIn() && getUserData().userRole == 'ScannerStaff';
    }

    function isAssignedStaff(eventId) {
      return isSignedIn() && (
        isScannerStaff() || 
        exists(/databases/$(database)/documents/events/$(eventId)/staffAssignments/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isSuperAdmin();
    }

    match /events/{eventId} {
      // Allow access if user is Admin of the event, SuperAdmin, or assigned Staff
      allow get, list: if isSignedIn() && (
        isSuperAdmin() || 
        (resource != null && resource.data.eventAdminId == request.auth.uid) ||
        isAssignedStaff(eventId)
      );
      
      allow create: if isEventAdmin();
      
      allow update, delete: if isSignedIn() && (
        isSuperAdmin() || 
        (resource != null && resource.data.eventAdminId == request.auth.uid)
      );
      
      // Allow access to subcollections for authorized users
      match /{allSubcollections=**} {
        allow get, list, write: if isSignedIn() && (
          isSuperAdmin() || 
          isAssignedStaff(eventId) ||
          (get(/databases/$(database)/documents/events/$(eventId)).data.eventAdminId == request.auth.uid)
        );
      }
    }

    match /venues/{venueId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}